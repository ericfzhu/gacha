{
  "name": "kantai-collection-web",
  "version": "2.0.0",
  "description": "Kantai Collection web game (React + Tailwind + Framer + Pixi + Cloudflare)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "api:dev": "wrangler dev",
