    "db:migrate": "wrangler d1 execute fleet-collection --file worker/schema.sql"
  },
  "dependencies": {
    "framer-motion": "^11.18.2",
    "pixi.js": "^8.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "5"
  },
  "packageManager": "yarn@4.12.0"
}
